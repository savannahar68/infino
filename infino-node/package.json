{
  "name": "@infino-ai/infino",
  "version": "0.1.6",
  "description": "Fast search on object storage — SQL, full-text, and vector search.",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/infino-ai/infino#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infino-ai/infino.git",
    "directory": "infino-node"
  },
  "bugs": {
    "url": "https://github.com/infino-ai/infino/issues"
  },
  "keywords": [
    "search",
    "vector",
    "database",
    "full-text-search",
    "vector-search",
    "vector-database",
    "hybrid-search",
    "semantic-search",
    "bm25",
    "ann",
    "knn",
    "sql",
    "ai",
    "llm",
    "rag",
    "agent-memory",
    "retrieval",
    "embeddings",
    "embedded-database",
    "object-storage",
    "parquet",
    "s3",
    "arrow",
    "typescript",
    "nodejs"
  ],
  "main": "infino/index.js",
  "types": "infino/index.d.ts",
  "exports": {
    ".": {
      "types": "./infino/index.d.ts",
      "default": "./infino/index.js"
    },
    "./package.json": "./package.json"
  },
  "napi": {
    "name": "infino",
    "package": {
      "name": "infx"
    },
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-musl"
      ]
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "napi build --platform --release --strip --js native.js --dts native.d.ts infino && tsc",
    "build:debug": "napi build --platform --js native.js --dts native.d.ts infino && tsc",
    "tsc": "tsc",
    "test": "node --test __test__/*.test.mjs",
    "artifacts": "napi artifacts -d artifacts"
  },
  "dependencies": {
    "apache-arrow": "^17"
  },
  "optionalDependencies": {
    "infx-darwin-x64": "0.1.6",
    "infx-darwin-arm64": "0.1.6",
    "infx-linux-x64-gnu": "0.1.6",
    "infx-linux-arm64-gnu": "0.1.6",
    "infx-linux-x64-musl": "0.1.6",
    "infx-linux-arm64-musl": "0.1.6"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "typescript": "^5"
  },
  "files": [
    "infino/index.js",
    "infino/index.d.ts",
    "infino/native.js",
    "infino/native.d.ts"
  ]
}
